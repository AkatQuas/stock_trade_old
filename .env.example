# 在这里 https://tushare.pro/weborder/#/user/info
# rename to `.env`，或运行 `uv run python setup.py` 自动生成
TUSHARE_TOKEN=your_tushare_token
# 智图股池 (qsgc/ztgc) 快照：https://www.zhituapi.com/get-free-cert.html
ZHITU_TOKEN=your_zhitu_token
# DeepSeek LLM 复盘（可选）：https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
LARK_APP_ID=your_lark_app_id
LARK_SECRET=your_lark_secret
ME_UNION_ID=your_union_id
# 飞书云文档存放文件夹 token（见 lark-doc.md）
LARK_FOLDER_TOKEN=your_lark_folder_token
# 可选：企业飞书域名，默认 feishu.cn
# LARK_DOC_DOMAIN=feishu.cn
