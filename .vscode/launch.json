{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Check One Symbol",
      "type": "debugpy",
      "request": "launch",
      "module": "stock_trade_z.check_code",
      "args": ["--symbol", "002549"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Select Stock",
      "type": "debugpy",
      "request": "launch",
      "module": "stock_trade_z.select_stock",
      "args": ["--data-dir", "./data"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Detect Risk",
      "type": "debugpy",
      "request": "launch",
      "module": "stock_trade_z.detect_risk",
      "args": ["--data-dir", "./data"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Fetch K Line",
      "type": "debugpy",
      "request": "launch",
      "module": "stock_trade_z.fetch_kline",
      "args": [
        "--start",
        "20240101",
        "--stocklist",
        "./stocklist.good.csv",
        "--out",
        "./data"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
